# ─── API Keys ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...         # Required if using Claude provider
                                            # Leave empty to auto-use Ollama

# ─── Encryption ─────────────────────────────────────────────────────────────
AES_KEY_HEX=                               # 32 bytes hex: openssl rand -hex 32

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL_SECONDS=900                 # 15 min
JWT_REFRESH_TTL_DAYS=30

# ─── Databases ──────────────────────────────────────────────────────────────
AUTH_DB_DSN=postgres://postgres:postgres@localhost:5432/auth_db?sslmode=disable
WORKSPACE_DB_DSN=postgres://postgres:postgres@localhost:5433/workspace_db?sslmode=disable
LABEL_DB_DSN=postgres://postgres:postgres@localhost:5434/label_db?sslmode=disable
AGENT_DB_DSN=postgres://postgres:postgres@localhost:5435/agent_db?sslmode=disable
PRINT_DB_DSN=postgres://postgres:postgres@localhost:5436/print_db?sslmode=disable

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Object Storage (MinIO for dev / Cloudflare R2 for prod) ────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=etiketai
S3_REGION=us-east-1                        # Required by S3 SDK even for MinIO

# ─── Ollama (on-premise AI provider) ────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llava:7b
VISION_TIMEOUT_SECONDS=60
TRANSL_TIMEOUT_SECONDS=30

# ─── Agent settings ─────────────────────────────────────────────────────────
AGENT_CACHE_TTL_SECONDS=300
MAX_RETRIES=3
COST_TRACKING_ENABLED=true

# ─── gRPC service addresses (used by api-gateway) ───────────────────────────
AUTH_SVC_ADDR=localhost:8081
WORKSPACE_SVC_ADDR=localhost:8082
LABEL_SVC_ADDR=localhost:8083
AGENT_SVC_ADDR=localhost:8084
PRINT_SVC_ADDR=localhost:8085
NOTIFICATION_SVC_ADDR=localhost:8086

# ─── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@etiketai.ro

# ─── OAuth ───────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# ─── Server ports ────────────────────────────────────────────────────────────
API_GATEWAY_PORT=8080
AUTH_SVC_PORT=8081
WORKSPACE_SVC_PORT=8082
LABEL_SVC_PORT=8083
AGENT_SVC_PORT=8084
PRINT_SVC_PORT=8085
NOTIFICATION_SVC_PORT=8086
ADMIN_SVC_PORT=8087

# ─── Environment ─────────────────────────────────────────────────────────────
ENV=development                            # development | staging | production
LOG_LEVEL=debug                            # debug | info | warn | error
